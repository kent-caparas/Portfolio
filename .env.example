# Copy to .env and fill in. Never commit the real .env.

# Anthropic API key for moderation (console.anthropic.com)
ANTHROPIC_API_KEY=

# Upstash Redis REST credentials (Upstash console -> database -> REST API tab)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Max submissions per IP per hour
WALL_RATE_LIMIT_PER_HOUR=5

# If false, every submission goes to the pending queue regardless of verdict
WALL_PUBLIC_RESULTS=true

# Hard daily cap on moderation calls; beyond this, submissions skip Claude and go to pending
WALL_DAILY_MAX_MODERATIONS=500

# Long random string gating the temporary admin endpoint (phase 2 only)
WALL_ADMIN_TOKEN=

# Moderation model — any structured-outputs-capable Claude model
WALL_MODERATION_MODEL=claude-haiku-4-5-20251001

# Public site origin, used for Slack links in phase 3
SITE_URL=https://yoursite.com

# Optional private prompt-injection filter: regex sources separated by ;;;
# (each compiled case-insensitive). Leave blank to rely on Claude + the pending
# queue. Keep the real patterns out of source control.
WALL_INJECTION_PATTERNS=
