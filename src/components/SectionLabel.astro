---
interface Props {
  text: string;
}

const { text } = Astro.props;
---

<div class="section-label" data-reveal>{text}</div>

<style>
  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-faint);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-line);
  }
</style>
