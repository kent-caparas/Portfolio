---
import Nav from './Nav.astro';

interface Props {
  /** Whether the name links back home (true on inner pages). */
  homeLink?: boolean;
}

const { homeLink = false } = Astro.props;

const NAME = 'kent caparas';
const VERSION = 'v0.4.1';
---

<header>
  <div class="system-line">
    <span>SYS::LOGBOOK {VERSION}</span>
    <span>ONLINE <span class="blink">●</span></span>
  </div>

  <h1>
    {
      homeLink ? (
        <a href="/">
          {NAME}
          <span class="accent">.</span>
        </a>
      ) : (
        <>
          {NAME}
          <span class="accent">.</span>
        </>
      )
    }
  </h1>

  <p class="tagline">
    <span class="hi">// </span>i build things, then i break them on purpose to
    see what falls out. sometimes i write about it. occasionally there are
    dragons.
  </p>

  <Nav />
</header>

<style>
  header {
    border-bottom: 1px dashed var(--color-line);
    padding-bottom: 32px;
    margin-bottom: 56px;
  }

  .system-line {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-ink-faint);
    letter-spacing: 0.05em;
    margin-bottom: 24px;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  .blink {
    color: var(--color-accent);
    animation: blink 1.2s steps(2) infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  h1 {
    font-family: var(--font-serif);
    font-weight: 800;
    font-size: clamp(40px, 7vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }

  h1 a {
    color: inherit;
    text-decoration: none;
  }

  h1 .accent {
    color: var(--color-accent);
    font-style: italic;
  }

  .tagline {
    font-size: 15px;
    color: var(--color-ink-dim);
    max-width: 480px;
  }

  .tagline .hi {
    color: var(--color-ink);
  }

  @media (prefers-reduced-motion: reduce) {
    .blink {
      animation: none;
    }
  }
</style>
