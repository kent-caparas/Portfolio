---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { formatStamp, formatTag } from '@/features/blog/lib/posts';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { title, date, tag, readingTime, excerpt } = post.data;
---

<BaseLayout title={`${title} — kent caparas`} description={excerpt}>
  <Header homeLink />

  <article>
    <div class="post-head">
      <div class="post-meta">
        <span>{formatStamp(date)}</span>
        <span class="tag">[{formatTag(tag)}]</span>
        {readingTime && <span>{readingTime} min</span>}
      </div>
      <h1 class="post-title">{title}</h1>
    </div>

    <div class="prose">
      <slot />
    </div>

    <p class="back"><a href="/blog">← back to logs</a></p>
  </article>

  <Footer lastUpdated={date} />
</BaseLayout>

<style>
  .post-head {
    margin-bottom: 40px;
  }

  .post-meta {
    display: flex;
    gap: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-faint);
    margin-bottom: 12px;
    letter-spacing: 0.04em;
  }

  .post-meta .tag {
    color: var(--color-good);
  }

  .post-title {
    font-family: var(--font-serif);
    font-weight: 800;
    font-size: clamp(30px, 5vw, 44px);
    line-height: 1.1;
    letter-spacing: -0.015em;
  }

  .back {
    margin-top: 56px;
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .back a {
    color: var(--color-ink-dim);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      color 0.15s,
      border-color 0.15s;
  }

  .back a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  /* MDX body — serif-led editorial prose */
  .prose {
    font-family: var(--font-serif);
    font-size: 19px;
    line-height: 1.7;
    color: var(--color-ink);
  }

  .prose :global(p) {
    margin: 0 0 20px;
  }

  .prose :global(h2),
  .prose :global(h3) {
    font-family: var(--font-serif);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin: 40px 0 12px;
    line-height: 1.2;
  }

  .prose :global(h2) {
    font-size: 28px;
  }
  .prose :global(h3) {
    font-size: 22px;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid var(--color-line);
  }

  .prose :global(a:hover) {
    border-bottom-color: var(--color-accent);
  }

  .prose :global(em) {
    font-style: italic;
    color: var(--color-accent);
  }

  .prose :global(strong) {
    font-weight: 700;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 20px;
    padding-left: 1.4em;
  }

  .prose :global(li) {
    margin-bottom: 8px;
  }

  .prose :global(blockquote) {
    margin: 24px 0;
    padding-left: 20px;
    border-left: 2px solid var(--color-accent);
    color: var(--color-ink-dim);
    font-style: italic;
  }

  /* code reads as a system voice — mono */
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.82em;
    background: var(--color-bg-soft);
    padding: 0.15em 0.4em;
    border-radius: 3px;
  }

  .prose :global(pre) {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.5;
    background: var(--color-bg-soft);
    border: 1px solid var(--color-line);
    border-radius: 4px;
    padding: 16px 18px;
    overflow-x: auto;
    margin: 0 0 24px;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: inherit;
  }
</style>
