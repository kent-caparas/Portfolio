---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import SectionLabel from '@/components/SectionLabel.astro';
import Footer from '@/components/Footer.astro';
import PostRow from '@/features/blog/components/PostRow.astro';
import { getPublishedPosts } from '@/features/blog/lib/posts';

const posts = await getPublishedPosts();
const lastUpdated = posts[0]?.data.date ?? new Date();
---

<BaseLayout
  title="logs — kent caparas"
  description="postmortems, teardowns, patch notes, and field notes from the logbook."
>
  <Header homeLink />

  <section>
    <SectionLabel text="all log entries" />
    {posts.map((post) => <PostRow post={post} />)}
  </section>

  <Footer lastUpdated={lastUpdated} />
</BaseLayout>

<style>
  section {
    margin-bottom: 72px;
  }
</style>
